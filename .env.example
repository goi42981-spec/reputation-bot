# Токен бота от @BotFather (обязательно)
BOT_TOKEN=1234567890:AAEx...

# Telegram user ID супер-владельца бота (опционально).
# Этот пользователь всегда имеет права владельца в любой группе, даже если он не владелец группы Telegram.
# Узнать свой ID можно через @userinfobot
# OWNER_ID=123456789

# Путь к файлу базы данных (опционально, по умолчанию reputation.db)
# DB_PATH=reputation.db
