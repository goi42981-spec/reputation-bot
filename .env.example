# Токен бота от @BotFather (обязательно)
BOT_TOKEN=1234567890:AAEx...

# Telegram user ID супер-владельца бота (опционально).
# Этот пользователь всегда имеет права владельца в любой группе,
# даже если он не владелец группы Telegram.
# Узнать свой ID можно через @userinfobot
# OWNER_ID=123456789

# Постоянное хранилище через PostgreSQL (например, бесплатный Neon).
# Если не задано — используется локальный SQLite по DB_PATH.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Путь к файлу SQLite (опционально, fallback при отсутствии DATABASE_URL,
# по умолчанию reputation.db).
# DB_PATH=reputation.db

# Whitelist чатов (опционально). Через запятую или пробел.
# Если не задано — бот отвечает в любой группе (по умолчанию).
# Если задано — бот молча игнорирует все остальные группы и личку.
# Команда /chatid всегда работает (используется для определения ID).
# ALLOWED_CHAT_IDS=-1001234567890,-1009876543210
